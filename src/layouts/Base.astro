---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const { title, description = SITE.description, ogImage = '/assets/images/ogp.png' } = Astro.props;
const pageTitle = title ? `${title}｜${SITE.name}` : `${SITE.name}｜長崎のAIシステム開発・AI相談・Web制作`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);

// ローカルビジネス構造化データ（Web検索・AI検索の両対応の要）
const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: SITE.name,
  description: SITE.description,
  url: Astro.site?.toString(),
  address: {
    '@type': 'PostalAddress',
    addressRegion: '長崎県',
    addressLocality: '長崎市',
  },
  areaServed: '長崎県',
  knowsAbout: ['AI活用支援', 'AIセミナー', '生成AI研修', 'ホームページ制作', 'Web保守'],
};
---

<!doctype html>
<html lang="ja">
  <head>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-740PJ5K47G"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-740PJ5K47G');
      // LINE友だち追加リンクのクリックを計測（リンク先が lin.ee なら発火）
      document.addEventListener('click', function (e) {
        var a = e.target.closest && e.target.closest('a[href*="lin.ee"]');
        if (a) gtag('event', 'line_click', { link_url: a.href });
      });
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/assets/images/logo-mark.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />

    <!-- OGP -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={SITE.name} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- フォント -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;500;700&family=Klee+One:wght@400;600&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
