---
import Base from '../layouts/Base.astro';
import CtaSection from '../components/CtaSection.astro';
import { SITE, CATEGORIES } from '../config';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;

// 制作実績（お客様コメント・URLは取得でき次第 config 化して表示）
const works = [
  {
    name: '大濱畳店 様',
    img: '/assets/images/works-ohama.png',
    alt: '大濱畳店様 ホームページ制作実績',
    url: 'https://ohama-tatami.co.jp/',
    voice: null, // TODO: 掲載許可済みコメント取得後に設定
  },
  {
    name: '中平個人タクシー 様',
    img: '/assets/images/works-nakahira.png',
    alt: '中平個人タクシー様 ホームページ制作実績',
    url: 'https://nagasaki-nakahira-taxi.jp/',
    voice: null,
  },
];
---

<Base>
  <!-- 1. ファーストビュー -->
  <section class="hero deco deco--dots-tr deco--ring-bl">
    <div class="container hero__inner">
      <div class="hero__copy">
        <h1>{SITE.catchcopy}</h1>
        <p>{SITE.subcopy}</p>
        <div class="hero__cta">
          <a href={SITE.lineUrl} class="btn btn--line">LINEで無料相談してみる</a>
          <a href="#service" class="btn btn--ghost">できることを見る</a>
        </div>
        <p class="hero__note">※ 相談は無料です。しつこい営業は一切しません。</p>
      </div>
      <div class="hero__img">
        <img
          src="/assets/images/hero.webp"
          alt="長崎の港が見える相談スペースで、店主と相談員が笑顔で話しているイラスト"
          width="1200"
          height="800"
        />
      </div>
    </div>
  </section>

  <!-- 2. こんなお悩みありませんか（共感ファースト） -->
  <section class="section deco deco--plus-tl deco--lines-br">
    <div class="container">
      <div class="section-title">
        <span class="section-title__sub">お悩み</span>
        <h2>こんなお悩み、ありませんか？</h2>
      </div>
      <div class="points">
        <div class="point-card">
          <img src="/assets/images/point-1.webp" alt="" width="600" height="600" loading="lazy" />
          <span class="point-card__label">その1</span>
          <p class="point-card__q">AIって、何から始めればいいの？</p>
          <p class="point-card__a">
            わからなくて当たり前です。ご相談に来る方のほとんどが、同じ状態からのスタート。あなたの仕事のどこでAIが使えるか、一緒に探すところからお手伝いします。
          </p>
        </div>
        <div class="point-card">
          <img src="/assets/images/point-2.webp" alt="" width="600" height="600" loading="lazy" />
          <span class="point-card__label">その2</span>
          <p class="point-card__q">うちみたいな小さな会社でも意味ある？</p>
          <p class="point-card__a">
            実は、小さい会社ほど効果が大きいのがAIです。1人で何役もこなしている仕事こそ、AIの出番です。
          </p>
        </div>
        <div class="point-card">
          <img src="/assets/images/point-3.webp" alt="" width="600" height="600" loading="lazy" />
          <span class="point-card__label">その3</span>
          <p class="point-card__q">パソコンも得意じゃないのに、大丈夫？</p>
          <p class="point-card__a">
            大丈夫です。スマホが使えれば十分。同じことを何度聞いてもらっても構いません。あなたのペースで、ひとつずつ進めます。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 2.5 ビフォーアフター実例（「事務が半分になる」を具体で見せる） -->
  <section class="section section--soft deco deco--dots-tr">
    <div class="container">
      <div class="section-title">
        <span class="section-title__sub">できること</span>
        <h2>たとえば、こんな作業が半分になります</h2>
      </div>
      <div class="cases">
        <div class="case-card">
          <p class="case-card__title"><span>見積書・請求書</span>作成の手間</p>
          <div class="case-panel case-panel--before">
            <span class="case-panel__label">いままで</span>
            毎回ゼロから手入力。似た案件を探して転記し、1件およそ30分。
          </div>
          <div class="case-card__arrow" aria-hidden="true">↓</div>
          <div class="case-panel case-panel--after">
            <span class="case-panel__label">AIとなら</span>
            よく使う文面や項目をAIに覚えさせて、下書きはおまかせ。あなたは確認と微調整だけ。<small>※最初の仕組みづくりからお手伝いします</small>
          </div>
          <p class="case-card__result">約30分 → 5分</p>
        </div>
        <div class="case-card">
          <p class="case-card__title"><span>SNS・お知らせ</span>の文章づくり</p>
          <div class="case-panel case-panel--before">
            <span class="case-panel__label">いままで</span>
            「何を書けばいいか」で手が止まり、1本に30分以上かかることも。
          </div>
          <div class="case-card__arrow" aria-hidden="true">↓</div>
          <div class="case-panel case-panel--after">
            <span class="case-panel__label">AIとなら</span>
            伝えたい内容を箇条書きで渡すと3案。選んで直すだけで完成。
          </div>
          <p class="case-card__result">約30分 → 10分</p>
        </div>
        <div class="case-card">
          <p class="case-card__title"><span>議事録・打合せメモ</span>の清書</p>
          <div class="case-panel case-panel--before">
            <span class="case-panel__label">いままで</span>
            録音を聞き直しながら清書。1時間の会議で作成に1時間。
          </div>
          <div class="case-card__arrow" aria-hidden="true">↓</div>
          <div class="case-panel case-panel--after">
            <span class="case-panel__label">AIとなら</span>
            音声から要点を自動で整理。見出しつきのメモにまとまります。
          </div>
          <p class="case-card__result">約60分 → 10分</p>
        </div>
      </div>
      <p class="cases__hook">
        「ChatGPTを触ってみたけど、続かなかった」——そんな方のご相談が、実は一番多いです。
      </p>
      <p class="cases__note">
        ※ 目安の一例です。「うちのこの作業はどう？」というご相談から一緒に探します。
      </p>
    </div>
  </section>

  <!-- 3. ごあいさつ（顔=安心を先に見せる） -->
  <section class="section">
    <div class="container">
      <div class="section-title">
        <span class="section-title__sub">ごあいさつ</span>
        <h2>こんな者がやっています</h2>
      </div>
      <div class="profile">
        <div class="profile__photo">
          <img src="/assets/images/profile.png" alt={`${SITE.name} 代表`} width="316" height="421" loading="lazy" />
        </div>
        <div class="profile__body">
          {SITE.owner && <h3>{SITE.owner}</h3>}
          <p class="profile__role">まちのAI屋さん 代表｜{SITE.area}</p>
          <p class="handwriting">
            はじめまして。「まちのAI屋さん」は、昔の「まちの電器屋さん」のように、困ったときに気軽に声をかけられるAIの相談相手でありたい、という思いで始めました。
          </p>
          <p class="handwriting">
            AIの話は、むずかしい言葉を使わなくても伝えられます。長崎の会社の現場に合わせて、わかることばでご説明します。
          </p>
          <p>
            <a href="/about/">くわしいプロフィールはこちら →</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3.5 選ばれる理由（3つの約束） -->
  <section class="section section--soft deco deco--plus-tl">
    <div class="container">
      <div class="section-title">
        <span class="section-title__sub">選ばれる理由</span>
        <h2>「まちのAI屋さん」3つの約束</h2>
      </div>
      <div class="promises">
        <div class="promise-card">
          <span class="promise-card__check" aria-hidden="true">✓</span>
          <h3>むずかしい言葉は使いません</h3>
          <p>専門用語ぬきで、わかることばだけでご説明します。同じことを何度聞いてもらっても構いません。</p>
        </div>
        <div class="promise-card">
          <span class="promise-card__check" aria-hidden="true">✓</span>
          <h3>売り込みはしません</h3>
          <p>必要なことだけをご提案します。合わなければ「聞くだけ」で終わってOKです。</p>
        </div>
        <div class="promise-card">
          <span class="promise-card__check" aria-hidden="true">✓</span>
          <h3>地元で、ずっと隣に</h3>
          <p>長崎の現場に合わせてサポート。保守もAI顧問も月額制で、「作って終わり」にしません。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. 3つのサービス -->
  <section class="section deco deco--dots-tr" id="service">
    <div class="container">
      <div class="section-title">
        <span class="section-title__sub">できること</span>
        <h2>3つのサービス</h2>
      </div>
      <div class="services">
        <div class="service-card">
          <img src="/assets/images/service-seminar.webp" alt="" width="400" height="400" loading="lazy" />
          <h3>AIセミナー</h3>
          <p>
            対面・ワークショップ形式で、翌日から使える内容だけをお届けするAI研修。長崎県の補助金が使える場合は、申請書類の作成まで一緒にやります。
          </p>
          <div class="service-card__link">
            <a href="/service/#seminar" class="btn btn--accent btn--sm">くわしく見る</a>
          </div>
        </div>
        <div class="service-card">
          <span class="badge badge--soon">2027年1月スタート予定</span>
          <img src="/assets/images/service-advisor.webp" alt="" width="400" height="400" loading="lazy" />
          <h3>AI顧問（月額制）</h3>
          <p>
            月額制でいつでも相談できる、AIの「かかりつけ相談相手」。導入して終わり、にはしません。先行のご相談を受け付けています。
          </p>
          <div class="service-card__link">
            <a href="/service/#advisor" class="btn btn--accent btn--sm">くわしく見る</a>
          </div>
        </div>
        <div class="service-card">
          <img src="/assets/images/service-web.webp" alt="" width="400" height="400" loading="lazy" />
          <h3>Web制作・保守</h3>
          <p>
            ホームページの制作から公開後の運用まで。保守は月額定額制なので、「作って終わり」になりません。
          </p>
          <div class="service-card__link">
            <a href="/service/#web" class="btn btn--accent btn--sm">くわしく見る</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. 制作実績・お客様の声 -->
  <section class="section section--soft">
    <div class="container">
      <div class="section-title">
        <span class="section-title__sub">お手伝いした実績</span>
        <h2>制作実績</h2>
      </div>
      <div class="works">
        {
          works.map((w) => (
            <div class="work-card">
              <div class="work-card__frame">
                <img src={w.img} alt={w.alt} loading="lazy" />
              </div>
              <div class="work-card__body">
                <h3>{w.name}</h3>
                {w.url && (
                  <a href={w.url} target="_blank" rel="noopener">
                    サイトを見る →
                  </a>
                )}
                {w.voice && <p class="work-card__voice">「{w.voice}」</p>}
              </div>
            </div>
          ))
        }
      </div>
      <p class="text-center mt-32">
        <a href="/works/" class="btn btn--ghost btn--sm">実績一覧を見る</a>
      </p>
    </div>
  </section>

  <!-- 6. 料金の目安 -->
  <section class="section deco deco--ring-tr">
    <div class="container">
      <div class="section-title">
        <span class="section-title__sub">料金</span>
        <h2>料金の目安</h2>
      </div>
      <div class="prices">
        <div class="price-card">
          <h3>AIセミナー</h3>
          <p class="price-card__price">内容に合わせて<br />お見積り</p>
          <p>補助金が使える場合は、実質負担を大きく抑えられます。使えるかどうかの確認から無料でお手伝いします</p>
        </div>
        <div class="price-card">
          <h3>AI顧問（月額制）</h3>
          <p class="price-card__price">2027年1月<br />スタート予定</p>
          <p>先行のご相談・優先案内のご希望を受付中です</p>
        </div>
        <div class="price-card">
          <h3>Web制作・保守</h3>
          <p class="price-card__price">保守 月額30,000円<small>（税別）</small></p>
          <p>制作費は内容により個別お見積り</p>
        </div>
      </div>
      <p class="text-center mt-32">
        <a href="/service/" class="btn btn--ghost btn--sm">サービスの詳細を見る</a>
      </p>
    </div>
  </section>

  <!-- 7. 相談の流れ（行動障壁の解消） -->
  <section class="section section--soft">
    <div class="container">
      <div class="section-title">
        <span class="section-title__sub">ご相談の流れ</span>
        <h2>相談って、何をするの？</h2>
      </div>
      <div class="flow">
        <div class="flow-card">
          <span class="flow-card__num">1</span>
          <h3>LINEでひとこと</h3>
          <p>「AIのこと聞きたい」と送るだけで始まります。かしこまった文章はいりません。</p>
        </div>
        <div class="flow-card">
          <span class="flow-card__num">2</span>
          <h3>雑談レベルでお話</h3>
          <p>今のお仕事の様子を、そのまま聞かせてください。準備はいりません。</p>
        </div>
        <div class="flow-card">
          <span class="flow-card__num">3</span>
          <h3>合わなければ、それっきりでOK</h3>
          <p>無理なおすすめは一切しません。「聞くだけ」で終わって大丈夫です。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. コラム -->
  {
    posts.length > 0 && (
      <section class="section deco deco--plus-tl">
        <div class="container">
          <div class="section-title">
            <span class="section-title__sub">読みもの</span>
            <h2>コラム・お知らせ</h2>
          </div>
          <div class="blog-list">
            {posts.map((post) => (
              <a href={`/blog/${post.id}/`} class="blog-card">
                <span class="blog-card__cat">{CATEGORIES[post.data.category]}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
              </a>
            ))}
          </div>
          <p class="text-center mt-32">
            <a href="/blog/" class="btn btn--ghost btn--sm">コラム一覧を見る</a>
          </p>
        </div>
      </section>
    )
  }

  <!-- 8.5 よくある質問（抜粋・不安の先回り） -->
  <section class="section section--soft">
    <div class="container article">
      <div class="section-title">
        <span class="section-title__sub">よくある質問</span>
        <h2>はじめてでも、大丈夫です</h2>
      </div>
      <div class="faq-item">
        <h3>AIのことが全然わからなくても相談していいですか？</h3>
        <p>もちろんです。「何を聞けばいいかわからない」という状態からのご相談が一番多いです。専門用語を使わずにご説明します。</p>
      </div>
      <div class="faq-item">
        <h3>相談にお金はかかりますか？</h3>
        <p>初回のご相談は無料です。LINEまたはお問い合わせフォームからお気軽にどうぞ。</p>
      </div>
      <div class="faq-item">
        <h3>会社の情報をAIに入れて大丈夫ですか？</h3>
        <p>入れていい情報・入れてはいけない情報の線引きからご説明します。情報を守るための設定を最初に一緒に行いますので、ご安心ください。</p>
      </div>
      <div class="faq-item">
        <h3>ホームページだけ、AIだけ、の相談でも大丈夫ですか？</h3>
        <p>大丈夫です。どちらか一方のご相談も歓迎です。両方まとめてのご相談ももちろん承ります。</p>
      </div>
      <p class="text-center mt-32">
        <a href="/faq/" class="btn btn--ghost btn--sm">よくある質問をもっと見る</a>
      </p>
    </div>
  </section>

  <!-- 9. 締めCTA -->
  <CtaSection />
</Base>
